# XJGPT experimental Cookie HTTP Adapter
# Copy this file to .env.local or set the variables in your terminal.
# Do not put real cookies, tokens, or school_gpt_state.json into GitHub.

# Adapter mode:
# - web: default Playwright web page automation
# - cookie: experimental direct HTTP call with local login cookies
XJGPT_ADAPTER_MODE=cookie

# XipuAI base URL
XIPUAI_BASE_URL=https://xipuai.xjtlu.edu.cn

# Required for cookie mode.
# Replace this with the authorized XipuAI backend chat endpoint.
XIPUAI_CHAT_ENDPOINT=/your/authorized/xipuai/chat/endpoint

# HTTP method used by the backend endpoint.
XIPUAI_API_METHOD=POST

# Payload style:
# - openai: {model, messages, stream}
# - simple: {question, model}
XIPUAI_PAYLOAD_STYLE=openai

# Local Playwright storage state generated by xjgpt-login.
XJGPT_STATE_FILE=school_gpt_state.json

# Optional: map frontend model id to real backend model code.
# XIPUAI_MODEL_GPT_5_4=real-backend-model-code
# XIPUAI_MODEL_DEEPSEEK_R1=real-backend-model-code
# XIPUAI_MODEL_DEEPSEEK_V3=real-backend-model-code
# XIPUAI_MODEL_QWEN_MAX=real-backend-model-code

# Optional: if backend needs auth token from localStorage.
# XIPUAI_AUTH_HEADER_FROM_LOCALSTORAGE=token_storage_key_here
# XIPUAI_AUTH_HEADER_NAME=Authorization
# XIPUAI_AUTH_HEADER_PREFIX=Bearer

# Optional: extra headers as JSON object.
# XIPUAI_EXTRA_HEADERS_JSON={"X-Requested-With":"XMLHttpRequest"}
